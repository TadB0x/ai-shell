{
  "name": "ai-shell",
  "version": "1.1.0",
  "description": "Type plain English. Get a shell command — powered by Claude AI.",
  "type": "module",
  "bin": {
    "ai": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/bundle.cjs",
    "build:binaries": "npm run bundle && node scripts/build-binaries.mjs",
    "dev": "node --loader ts-node/esm src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@google/genai": "^1.49.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "groq-sdk": "^1.1.2",
    "inquirer": "^12.6.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@yao-pkg/pkg": "^6.14.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.8"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "shell",
    "cli",
    "claude",
    "anthropic",
    "terminal",
    "nlp",
    "linux",
    "bash"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ai-shell"
  },
  "homepage": "https://github.com/yourusername/ai-shell#readme"
}
